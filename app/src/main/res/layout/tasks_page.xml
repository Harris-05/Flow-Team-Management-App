<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="#F4F7FC"
    android:id="@+id/main"
    android:fitsSystemWindows="true">

    <!-- ========================================================= -->
    <!-- TOP SCROLLABLE CONTENT -->
    <!-- ========================================================= -->
    <ScrollView
        android:id="@+id/scrollArea"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNav"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- TOP BLUE HEADER -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="130dp"
                android:background="@drawable/home_page_top_section"
                android:padding="20dp">

                <TextView
                    android:id="@+id/pageTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tasks"
                    android:textColor="@android:color/white"
                    android:textSize="20sp" />

                <!-- Search bar background -->
                <RelativeLayout
                    android:id="@+id/searchBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/pageTitle"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/search_box_bg"
                    android:padding="12dp">

                    <ImageView
                        android:id="@+id/searchIcon"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/search_icon"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        app:tint="#AFC4FF" />

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/searchIcon"
                        android:layout_marginStart="12dp"
                        android:hint="Search organizations..."
                        android:textSize="14sp"
                        android:background="@android:color/transparent"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#AFC4FF"
                        android:layout_centerVertical="true"/>
                </RelativeLayout>

            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:padding="12dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="16sp"
                    android:text="Tasks for you"
                    android:gravity="center"
                    android:textColor="#1e90ff"
                    android:clickable="true"
                    android:focusable="true">


                </TextView>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="16sp"
                    android:text="Tasks by you"
                    android:gravity="center"
                    android:textColor="#8293B5">


                </TextView>

            </LinearLayout>

            <View
                android:layout_width="215dp"
                android:layout_height="2dp"
                android:background="#1e90ff"
                >

            </View>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="18dp"
                >
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/oblong_blue"
                    android:text="All"
                    android:textSize="12sp"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:layout_marginHorizontal="6dp"
                    android:clickable="true"
                    android:focusable="true">

                </TextView>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/oblong_white"
                    android:text="Pending"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginHorizontal="6dp"
                    android:clickable="true"
                    android:focusable="true">

                </TextView>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/oblong_white"
                    android:text="In Progress"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginHorizontal="6dp"
                    android:clickable="true"
                    android:focusable="true">

                </TextView>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/oblong_white"
                    android:text="Pending"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginHorizontal="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    >

                </TextView>

            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:listitem="@layout/tasks_page_card"
                android:layout_marginTop="18dp">

            </androidx.recyclerview.widget.RecyclerView>

        </LinearLayout>


    </ScrollView>




    <!-- ========================================================= -->
    <!-- FIXED BOTTOM NAVIGATION BAR -->
    <!-- ========================================================= -->

    <RelativeLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true"
        android:paddingHorizontal="30dp"
        android:paddingTop="8dp"
        android:background="@color/white"
        >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:weightSum="5"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Home -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/home"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Home"
                    android:textColor="#7A8FA6"
                    android:textSize="11sp"/>
            </LinearLayout>

            <!-- Teams -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/building"
                    />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Organisations"
                    android:textColor="#8293B5"
                    android:textSize="11sp"/>
            </LinearLayout>

            <!-- Tasks -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/task_active"
                    />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tasks"
                    android:textColor="#1e90ff"
                    android:textSize="11sp"/>
            </LinearLayout>

            <!-- Notifications -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/bell"
                    />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Notifications"
                    android:textColor="#7A8FA6"
                    android:textSize="11sp"/>
            </LinearLayout>

            <!-- Profile -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/profile_icon"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profile"
                    android:textColor="#7A8FA6"
                    android:textSize="11sp"/>
            </LinearLayout>

        </LinearLayout>
    </RelativeLayout>

</RelativeLayout>