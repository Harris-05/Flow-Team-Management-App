<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FB"
    tools:context=".view_attendance">

    <!-- 🔵 Top Blue Header -->
    <View
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="130dp"
        android:background="@color/dark_blue"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 🕓 View Attendance Title -->
    <TextView
        android:id="@+id/tvViewAttendanceTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="View Attendance"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvEmployeeName"
        android:paddingTop="24dp"
        android:fontFamily="@font/poppins_medium"/>

    <!-- 🧑 Employee Name (Subtitle) -->
    <TextView
        android:id="@+id/tvEmployeeName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Emp Name"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:paddingBottom="16dp"
        android:fontFamily="@font/poppins_medium"/>

    <!-- 🕓 Total Time Worked Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardTotalHours"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:layout_marginTop="20dp"
        android:layout_marginHorizontal="20dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="5dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvTotalHoursLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Time Worked"
                android:textColor="#1E293B"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_medium"/>

            <TextView
                android:id="@+id/tvTotalHours"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 hrs"
                android:textColor="#475569"
                android:textSize="26sp"
                android:paddingTop="6dp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_medium"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
