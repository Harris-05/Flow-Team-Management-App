<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <!-- Top Bar (Same theme as All Chats Screen) -->
    <LinearLayout
        android:id="@+id/top_bar_add_chat"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:background="#0A2647">

        <ImageView
            android:id="@+id/back_button_add_chat"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/nav_back"
            app:tint="@android:color/white"
             />

        <TextView
            android:id="@+id/title_text_add_chat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Start a new chat"
            android:textAlignment="center"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/instagram_sans"/>

        <!-- Right side spacer to balance back button -->
        <View
            android:layout_width="28dp"
            android:layout_height="28dp"/>
    </LinearLayout>

    <!-- RecyclerView for listing all users -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewUsers"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="8dp"
        android:paddingHorizontal="4dp"
        android:clipToPadding="false"
        android:scrollbars="vertical"
        tools:listitem="@layout/user_item_layout"/>

</LinearLayout>
