<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FC"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <!-- SCROLLABLE CONTENT -->
    <ScrollView
        android:id="@+id/scrollContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- TOP SECTION -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="15dp"
                android:background="@drawable/home_page_top_section">

                <!-- Profile Picture -->
                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/ivProfile"
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:layout_alignParentEnd="true"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="15dp"
                    android:src="@drawable/baseline_person_24"
                    >

                </de.hdodenhof.circleimageview.CircleImageView>

                <!-- Notification Button -->
                <ImageView
                    android:id="@+id/ivNotificationButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_toStartOf="@id/ivProfile"
                    android:layout_marginTop="15dp"
                    android:contentDescription="Notifications"
                    android:src="@drawable/notification_button" />

                <!-- Greeting -->
                <TextView
                    android:id="@+id/tvHello"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Hello, Name"
                    android:textColor="@android:color/white"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tvHello"
                    android:text="Ready to manage your team?"
                    android:textColor="#AFC4FF"
                    android:textSize="12sp" />

                <!-- STATS GRID -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="60dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- LEFT COLUMN -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:padding="5dp">

                        <!-- Active Tasks -->
                        <RelativeLayout
                            android:id="@+id/active_tasks_card"
                            android:layout_width="match_parent"
                            android:layout_height="80dp"
                            android:background="@drawable/stat_card"
                            android:padding="12dp">

                            <RelativeLayout
                                android:id="@+id/clock_icon"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:layout_centerVertical="true"
                                android:background="@drawable/blue_square">

                                <ImageView
                                    android:layout_width="25dp"
                                    android:layout_height="25dp"
                                    android:layout_centerInParent="true"
                                    android:contentDescription="Clock Icon"
                                    android:src="@drawable/clock_icon" />
                            </RelativeLayout>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_toEndOf="@id/clock_icon"
                                android:layout_centerVertical="true"
                                android:orientation="vertical"
                                android:paddingStart="8dp">

                                <TextView
                                    android:id="@+id/task_count"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@android:color/white"
                                    android:textSize="22sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Active Tasks"
                                    android:textColor="#AFC4FF"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </RelativeLayout>

                        <!-- Pending Tasks -->
                        <RelativeLayout
                            android:id="@+id/pending_tasks_card"
                            android:layout_width="match_parent"
                            android:layout_height="80dp"
                            android:layout_marginTop="15dp"
                            android:background="@drawable/stat_card"
                            android:padding="12dp">

                            <RelativeLayout
                                android:id="@+id/warning_icon"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:layout_centerVertical="true"
                                android:background="@drawable/orange_square">

                                <ImageView
                                    android:layout_width="25dp"
                                    android:layout_height="25dp"
                                    android:layout_centerInParent="true"
                                    android:contentDescription="Warning Icon"
                                    android:src="@drawable/warning_icon" />
                            </RelativeLayout>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_toEndOf="@id/warning_icon"
                                android:layout_centerVertical="true"
                                android:orientation="vertical"
                                android:paddingStart="8dp">

                                <TextView
                                    android:id="@+id/pending_count"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@android:color/white"
                                    android:textSize="22sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Pending"
                                    android:textColor="#AFC4FF"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </RelativeLayout>
                    </LinearLayout>

                    <!-- RIGHT COLUMN -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:padding="5dp">

                        <!-- Completed Tasks -->
                        <RelativeLayout
                            android:id="@+id/completed_tasks_card"
                            android:layout_width="match_parent"
                            android:layout_height="80dp"
                            android:background="@drawable/stat_card"
                            android:padding="12dp">

                            <RelativeLayout
                                android:id="@+id/tick_icon"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:layout_centerVertical="true"
                                android:background="@drawable/green_square">

                                <ImageView
                                    android:layout_width="25dp"
                                    android:layout_height="25dp"
                                    android:layout_centerInParent="true"
                                    android:contentDescription="Tick Icon"
                                    android:src="@drawable/tick_icon" />
                            </RelativeLayout>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_toEndOf="@id/tick_icon"
                                android:layout_centerVertical="true"
                                android:orientation="vertical"
                                android:paddingStart="8dp">

                                <TextView
                                    android:id="@+id/completed_count"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@android:color/white"
                                    android:textSize="22sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Completed"
                                    android:textColor="#AFC4FF"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </RelativeLayout>

                        <!-- Completion Rate -->
                        <RelativeLayout
                            android:id="@+id/completion_rate_card"
                            android:layout_width="match_parent"
                            android:layout_height="80dp"
                            android:layout_marginTop="15dp"
                            android:background="@drawable/stat_card"
                            android:padding="12dp">

                            <RelativeLayout
                                android:id="@+id/arrow_icon"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:layout_centerVertical="true"
                                android:background="@drawable/purple_square">

                                <ImageView
                                    android:layout_width="25dp"
                                    android:layout_height="25dp"
                                    android:layout_centerInParent="true"
                                    android:contentDescription="Arrow Icon"
                                    android:src="@drawable/arrow_icon" />
                            </RelativeLayout>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_toEndOf="@id/arrow_icon"
                                android:layout_centerVertical="true"
                                android:orientation="vertical"
                                android:paddingStart="8dp">

                                <TextView
                                    android:id="@+id/completion_rate"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@android:color/white"
                                    android:textSize="22sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Completion"
                                    android:textColor="#AFC4FF"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </RelativeLayout>
                    </LinearLayout>
                </LinearLayout>
            </RelativeLayout>

            <!-- CONTENT AREA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="@android:color/white">

                <!-- Quick Actions title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quick Actions"
                    android:textSize="18sp"
                    android:textColor="#001542"
                    android:textStyle="bold"
                    android:layout_marginBottom="14dp" />

                <!-- Quick Action Cards -->
                <!-- TEAMS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:layout_marginBottom="10dp"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:background="@drawable/action_card">

                    <RelativeLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_centerVertical="true"
                        android:background="@drawable/icon_square">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_centerInParent="true"
                            android:contentDescription="Teams Icon"
                            android:src="@drawable/team_icon" />
                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Teams"
                            android:textSize="13sp"
                            android:textColor="#001542" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Manage team collaboration"
                            android:textSize="13sp"
                            android:textColor="#6E7D91" />
                    </LinearLayout>
                </LinearLayout>

                <!-- MY TASKS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:layout_marginBottom="10dp"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:background="@drawable/action_card">

                    <RelativeLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_centerVertical="true"
                        android:background="@drawable/icon_square">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_centerInParent="true"
                            android:contentDescription="My Tasks Icon"
                            android:src="@drawable/tick_icon" />
                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="My Tasks"
                            android:textSize="13sp"
                            android:textColor="#001542" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="View assigned tasks"
                            android:textSize="13sp"
                            android:textColor="#6E7D91" />
                    </LinearLayout>
                </LinearLayout>

                <!-- NOTIFICATIONS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:layout_marginBottom="10dp"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:background="@drawable/action_card">

                    <RelativeLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_centerVertical="true"
                        android:background="@drawable/icon_square">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_centerInParent="true"
                            android:contentDescription="Notifications Icon"
                            android:src="@drawable/bell_icon" />
                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Notifications"
                            android:textSize="13sp"
                            android:textColor="#001542" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Check updates"
                            android:textSize="13sp"
                            android:textColor="#6E7D91" />
                    </LinearLayout>
                </LinearLayout>

                <!-- CHECK-IN BUTTON -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:background="@drawable/check_in_out_button">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:text="Check In/Out"
                        android:textSize="12sp"
                        android:textColor="@color/white"
                        android:translationX="5dp"
                        android:translationY="-1dp" />
                </RelativeLayout>

                <!-- RECENT ACTIVITY -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:layout_marginBottom="10dp"
                    android:text="Recent Activity"
                    android:textSize="18sp"
                    android:textColor="#001542"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    tools:listitem="@layout/activity_cards" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- FLOATING CHAT -->
    <ImageView
        android:id="@+id/floatingChat"
        android:layout_width="65dp"
        android:layout_height="65dp"
        android:layout_alignParentEnd="true"
        android:layout_above="@id/bottomNav"
        android:layout_margin="22dp"
        android:contentDescription="Chat"
        android:src="@drawable/chat_icon" />

    <!-- BOTTOM NAVIGATION -->
    <RelativeLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true"
        android:background="@color/white"
        android:paddingHorizontal="30dp"
        android:paddingTop="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:weightSum="5">

            <!-- Home -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/home_active"
                    android:contentDescription="Home" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Home"
                    android:textColor="#2F80FF"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Projects -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:id="@+id/Projects">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/building"
                    android:contentDescription="Projects" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Projects"
                    android:textColor="#7A8FA6"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Tasks -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:id="@+id/Tasks">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/task"
                    android:contentDescription="Tasks" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tasks"
                    android:textColor="#7A8FA6"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Notifications -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:id="@+id/Notifications">


                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/bell"
                    android:contentDescription="Notifications" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Notifications"
                    android:textColor="#7A8FA6"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Profile -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:id="@+id/Profile">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/profile_icon"
                    android:contentDescription="Profile" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profile"
                    android:textColor="#7A8FA6"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>
</RelativeLayout>
