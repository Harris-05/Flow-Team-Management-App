<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FC"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Task Title -->
        <TextView
            android:id="@+id/tvTaskTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Task Title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginBottom="12dp"/>

        <!-- Status and Priority -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="In Progress"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:background="@drawable/chip_blue"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvPriority"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="High"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:background="@drawable/chip_red"/>
        </LinearLayout>

        <!-- Description -->
        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Task description goes here..."
            android:textSize="16sp"
            android:textColor="#5D6D7E"
            android:layout_marginTop="16dp"
            android:lineSpacingExtra="4dp"/>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginVertical="16dp"/>

        <!-- Assigned To -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Assigned To:"
            android:textSize="14sp"
            android:textColor="#7F8C8D"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvAssignedTo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="User Name"
            android:textSize="16sp"
            android:textColor="#1A1A2E"
            android:layout_marginBottom="12dp"/>

        <!-- Team / Organization -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Team / Organization:"
            android:textSize="14sp"
            android:textColor="#7F8C8D"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvTeamOrg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UI/UX Team / Flow Inc."
            android:textSize="16sp"
            android:textColor="#1A1A2E"
            android:layout_marginBottom="12dp"/>

        <!-- Deadline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Deadline:"
            android:textSize="14sp"
            android:textColor="#7F8C8D"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvDeadline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2025-12-05"
            android:textSize="16sp"
            android:textColor="#1A1A2E"
            android:layout_marginBottom="20dp"/>

        <!-- Optional Update Requested -->
        <TextView
            android:id="@+id/tvUpdateRequested"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Update Requested"
            android:textSize="14sp"
            android:textColor="#E67E22"
            android:visibility="gone"
            android:layout_marginBottom="20dp"/>

        <!-- Optional Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnMarkComplete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mark Completed"
                android:backgroundTint="#2ECC71"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="12dp"/>

            <Button
                android:id="@+id/btnEditTask"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Edit Task"
                android:backgroundTint="#3498DB"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
