<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#F4F7FC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title -->
        <TextView
            android:id="@+id/tvTaskTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Task Title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginBottom="12dp" />

        <!-- Status + Priority Chips -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="In Progress"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:background="@drawable/chip_blue"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvPriority"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="High"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:background="@drawable/chip_red" />
        </LinearLayout>

        <!-- Description -->
        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Task description goes here..."
            android:textSize="16sp"
            android:textColor="#5D6D7E"
            android:layout_marginTop="16dp"
            android:lineSpacingExtra="4dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginVertical="16dp" />

        <!-- Assigned By -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Assigned By:"
            android:textStyle="bold"
            android:textColor="#7F8C8D" />

        <TextView
            android:id="@+id/tvAssignedBy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Manager Name"
            android:textSize="16sp"
            android:textColor="#1A1A2E"
            android:layout_marginBottom="12dp" />

        <!-- Assigned To -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Assigned To:"
            android:textStyle="bold"
            android:textColor="#7F8C8D" />

        <TextView
            android:id="@+id/tvAssignedTo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="User Name"
            android:textSize="16sp"
            android:textColor="#1A1A2E"
            android:layout_marginBottom="16dp" />

        <!-- DEADLINE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Deadline:"
            android:textStyle="bold"
            android:textColor="#7F8C8D" />

        <TextView
            android:id="@+id/tvDeadline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2025-12-05"
            android:textSize="16sp"
            android:textColor="#1A1A2E"
            android:layout_marginBottom="20dp" />

        <!-- MANAGER ONLY: Request Update Button -->
        <Button
            android:id="@+id/btnRequestUpdate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Request Update"
            android:backgroundTint="#F39C12"
            android:textColor="#FFFFFF"
            android:visibility="gone"
            android:layout_marginBottom="20dp" />

        <!-- MEMBER ONLY: Upload Update Section -->
        <LinearLayout
            android:id="@+id/memberUpdateSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Upload Progress Image:"
                android:textStyle="bold"
                android:textColor="#7F8C8D" />

            <ImageView
                android:id="@+id/imgPreview"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="8dp"
                android:scaleType="centerCrop"
                android:background="#DCDCDC" />

            <Button
                android:id="@+id/btnChooseImage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Choose Image"
                android:layout_marginTop="10dp"
                android:backgroundTint="#3498DB"
                android:textColor="#fff" />

            <EditText
                android:id="@+id/etUpdateMessage"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:hint="Write your update..."
                android:gravity="top"
                android:background="@drawable/bg_edittext"
                android:padding="10dp"
                android:layout_marginTop="12dp" />

            <Button
                android:id="@+id/btnSubmitUpdate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Submit Update"
                android:backgroundTint="#2ECC71"
                android:textColor="#FFFFFF"
                android:layout_marginTop="10dp" />
        </LinearLayout>

        <!-- MANAGER ONLY: View Submitted Update -->
        <LinearLayout
            android:id="@+id/managerViewUpdateSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Latest Update:"
                android:textStyle="bold"
                android:textColor="#7F8C8D" />

            <ImageView
                android:id="@+id/imgSubmittedUpdate"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="8dp"
                android:scaleType="centerCrop"
                android:background="#DCDCDC" />

            <TextView
                android:id="@+id/tvSubmittedMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No updates yet..."
                android:textSize="15sp"
                android:textColor="#1A1A2E"
                android:layout_marginTop="10dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
