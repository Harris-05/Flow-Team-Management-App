<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:padding="0dp"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <RelativeLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/home_page_top_section"
        android:layout_width="match_parent"
        android:layout_height="80dp">

        <ImageView
            android:id="@+id/backBtn"
            android:src="@drawable/back_arrow"
            android:layout_width="44dp"
            android:layout_height="34dp"
            android:layout_alignTop="@id/selectTitle"/>

        <TextView
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:text="Select a Project"
            android:layout_toRightOf="@id/backBtn"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:fontFamily="@font/poppins_medium"
            android:id="@+id/selectTitle"
            />
    </RelativeLayout>


    <!-- Title -->
    <TextView
        android:text="Your Projects"
        android:textStyle="bold"
        android:textSize="22sp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:textColor="@color/black"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_medium"/>

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/orgRecycler"
        android:layout_width="match_parent"
        android:padding="8dp"
        tools:listitem="@layout/org_list_item"
        android:layout_height="match_parent"/>

</LinearLayout>
