<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:orientation="vertical"
        android:paddingBottom="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- HEADER -->
        <RelativeLayout
            android:background="@drawable/home_page_top_section"
            android:padding="16dp"
            android:elevation="4dp"
            android:layout_width="match_parent"
            android:layout_height="100dp">

            <ImageView
                android:id="@+id/backBtn"
                android:src="@drawable/back_arrow"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true" />

            <LinearLayout
                android:orientation="vertical"
                android:layout_toEndOf="@id/backBtn"
                android:layout_marginStart="16dp"
                android:layout_centerVertical="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Attendance"
                    android:textColor="@android:color/white"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_medium"/>

                <TextView
                    android:id="@+id/tvProjectName"
                    android:text="Project Name"
                    android:textSize="14sp"
                    android:textColor="#D0D8E8"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_medium"/>
            </LinearLayout>
        </RelativeLayout>

        <!-- TIME / DATE / LOCATION CARD -->
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:layout_margin="16dp"
            android:padding="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:elevation="4dp"
            android:clipToPadding="false">

            <TextView
                android:id="@+id/tvTime"
                android:text="03:45:07 AM"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#0A2A53"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_medium"/>

            <TextView
                android:id="@+id/tvDate"
                android:text="Sunday, October 5, 2025"
                android:textSize="14sp"
                android:textColor="#5B6770"
                android:gravity="center"
                android:layout_marginTop="4dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_medium"/>

            <TextView
                android:id="@+id/tvLocation"
                android:text="Islamabad, Pakistan"
                android:textSize="14sp"
                android:textColor="#5B6770"
                android:gravity="center"
                android:layout_marginTop="4dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_medium"/>
        </LinearLayout>

        <!-- STATUS CARD -->
        <LinearLayout
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:elevation="2dp">

            <TextView
                android:id="@+id/tvStatus"
                android:text="Not Checked In"
                android:textColor="#8A94A4"
                android:textSize="16sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_medium"/>
        </LinearLayout>

        <!-- CHECK-IN BUTTON -->
        <LinearLayout
            android:background="@drawable/btn_green"
            android:id="@+id/btnCheckIn"
            android:layout_marginTop="22dp"
            android:layout_marginHorizontal="16dp"
            android:padding="16dp"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Check In"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_medium"/>

        </LinearLayout>

        <!-- CHECK-OUT BUTTON -->
        <LinearLayout
            android:id="@+id/btnCheckOut"
            android:visibility="gone"
            android:background="@drawable/btn_red"
            android:layout_marginTop="22dp"
            android:layout_marginHorizontal="16dp"
            android:padding="16dp"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Check Out"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- ACTIVE TIME -->
        <TextView
            android:id="@+id/tvActiveTime"
            android:text="Active Time: 00h 00m"
            android:visibility="gone"
            android:textColor="#0A2A53"
            android:textSize="15sp"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- TOTAL TIME WORKED -->
        <TextView
            android:id="@+id/tvTotalTimeWorked"
            android:text="Total Worked: 00:00:00"
            android:textColor="#0A2A53"
            android:textSize="15sp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_medium"/>

    </LinearLayout>

</ScrollView>
